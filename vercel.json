{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    { "path": "/api/radar", "schedule": "0 5 * * *" },
    { "path": "/api/radar?urgentOnly=1", "schedule": "*/30 * * * *" },
    { "path": "/api/report?period=week&send=1", "schedule": "0 6 * * 1" },
    { "path": "/api/geo?send=1", "schedule": "0 7 * * 1" }
  ],
  "rewrites": [
    { "source": "/stats", "destination": "/stats.html" },
    { "source": "/context", "destination": "/context.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/guide", "destination": "/guide.html" },
    { "source": "/auth/verify", "destination": "/api/verify" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    }
  ],
  "functions": {
    "api/radar.js": { "maxDuration": 60 }
  }
}
