# ── PR Radar — environment ────────────────────────────────────────────────
# Standalone brand & reputation monitor. Shares the Regulatory Radar's Supabase
# PROJECT but writes only pr_* tables, so it never touches regulatory data.

# Claude API (classifier + semantic dedup). Recommended: a SEPARATE key from the
# Regulatory Radar so PR classification spend never touches that app's budget.
ANTHROPIC_API_KEY=
CLASSIFIER_MODEL=claude-haiku-4-5-20251001

# Supabase — the SAME project as the Regulatory Radar (this app uses pr_* tables
# only). Reuse that project's URL + service-role key here.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend).
RESEND_API_KEY=
RADAR_FROM="PR Radar <pr-radar@yourdomain.com>"
RADAR_TO="Name <someone@vodafone.com>, another@vodafone.com"
# Optional silent monitor (BCC) copy, and addresses to keep off it:
RADAR_BCC=
RADAR_BCC_EXCLUDE=

# Auth. CRON_SECRET is injected by Vercel Cron (Bearer). RADAR_TOKEN is now a
# READ-ONLY service token accepted ONLY in the Authorization header (Bearer) —
# never in a ?t= query string (Task 18). Human access is password sign-in; the
# board/stats/admin no longer accept ?t= at all. Sign-in is brute-force throttled.
CRON_SECRET=
RADAR_TOKEN=

# ── User sign-in, RBAC & audit (Task 16) ────────────────────────────────────
# Email + PASSWORD sign-in via Supabase Auth (no confirmation email — accounts are
# created pre-confirmed by the admin API). Only allowlisted emails may create an
# account or sign in (ADMIN_EMAILS + the pr_users table); everyone else is blocked.
# Requires Supabase → Authentication → Providers → "Email" enabled (default on).
# A magic-link fallback (POST mode=magiclink) also exists but isn't used by the UI;
# it's the only thing that needs the Redirect-URL setup noted below.
#
# ADMIN_EMAILS: CSV of emails that are ALWAYS admin — bootstrap + lock-out
# insurance. The pr_users table holds everyone else (managed from /admin).
ADMIN_EMAILS=tamer.basha@vodafone.com
# SUPABASE_ANON_KEY: the project's public anon key (safe to expose). Used by the
# frontend to refresh an expiring session, and server-side to validate tokens
# when SUPABASE_JWT_SECRET is not set.
SUPABASE_ANON_KEY=
# SUPABASE_JWT_SECRET: the project's JWT secret (Supabase → Settings → API →
# JWT Settings). If set, session tokens are verified locally (fast, no network).
# If unset, tokens are validated via a GoTrue round-trip instead.
SUPABASE_JWT_SECRET=
#
# Supabase Auth setup (one-time, in the Supabase dashboard → Authentication):
#   • URL Configuration → add BOARD_URL to "Redirect URLs" so the magic link can
#     land back on the board (e.g. https://your-pr-radar.vercel.app/).
#   • The magic-link email itself is sent through the app's Resend sender, so no
#     Supabase SMTP configuration is required.

# Public board URL — used for email deep-links and /api/go share links.
BOARD_URL=https://your-pr-radar.vercel.app/

# Optional: Slack / Teams / Discord incoming webhook for severity-5 URGENT alerts.
URGENT_WEBHOOK_URL=

# Optional: WhatsApp Cloud API for severity-5 URGENT alerts, sent as 1:1 DMs to
# each recipient (WhatsApp's official API can't post to a group). Business-
# initiated messages need a Meta-APPROVED template whose body has one variable
# {{1}} (the alert line); put the board link in the template as static text.
# All OFF unless WHATSAPP_ENABLED=1 AND token/phone-id/recipients are set.
#   WHATSAPP_ENABLED        1 to turn it on (off by default)
#   WHATSAPP_TOKEN          Cloud API permanent (system-user) access token
#   WHATSAPP_PHONE_ID       the sender number's PHONE NUMBER ID (from Meta)
#   WHATSAPP_TO             recipient numbers, E.164 digits only, CSV (e.g. 2010…,2011…)
#   WHATSAPP_TEMPLATE       approved template name (default pr_urgent)
#   WHATSAPP_TEMPLATE_LANG  template language code (default en)
#   WHATSAPP_GRAPH_VERSION  Graph API version (default v21.0)
WHATSAPP_ENABLED=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TO=
WHATSAPP_TEMPLATE=
WHATSAPP_TEMPLATE_LANG=

# Weekly / monthly report (/api/report). The printable HTML is always available
# to a token holder; the EMAIL send is opt-in and OFF unless this is set to 1.
# The weekly vercel.json cron (Mon 06:00 UTC) fires regardless but only emails
# when the flag is on, so the schedule stays dormant until the team opts in.
REPORT_EMAIL_ENABLED=
# Report recipients (CSV, "Name <email>" ok). Falls back to RADAR_TO if unset.
REPORT_TO=

# Cross-item SURGE detection (aggregate negative-volume spike per brand). The
# surge is always computed + logged + counted in the run stats; the EMAIL/webhook
# only fire when this is 1 (off by default — watch it before letting it email).
SURGE_ALERTS_ENABLED=
# Surge recipients (CSV). Falls back to RADAR_TO if unset. Webhook reuses URGENT_WEBHOOK_URL.
SURGE_TO=
# Tuning (all optional; sensible defaults in lib/surge.js):
#   SURGE_WINDOW_DAYS  trailing baseline window (default 21)
#   SURGE_K            std-devs above the mean to trip (default 2)
#   SURGE_MIN_VOLUME   weighted-negative floor so quiet brands don't cry wolf (default 4)
#   SURGE_THROTTLE_HOURS  min hours between alerts for the same brand (default 12)
SURGE_WINDOW_DAYS=
SURGE_K=
SURGE_MIN_VOLUME=
SURGE_THROTTLE_HOURS=
# Window shape. Default (unset) buckets by CALENDAR day, so "today" is partial
# early in the Cairo day and under-detects. Set to 1 to compare the trailing
# rolling 24h against prior rolling-24h windows instead. Both are computed and
# logged every run ("surge detect · calendar-day:[…] · rolling-24h:[…]"); this
# flag only chooses which one is returned/alertable. Calibrate from the logs
# first, then enable.
SURGE_ROLLING=

# AI answer-engine (GEO) monitoring (/api/geo). Probes major answer engines
# about Vodafone Egypt and audits each answer (via the classifier model +
# house facts) for factual drift / negative framing. OFF by default and
# cost-bounded: nothing runs unless GEO_ENABLED=1, and each engine stays
# dormant until its own key is set. The weekly cron (Mon 07:00 UTC) no-ops
# while disabled. Audit reuses ANTHROPIC_API_KEY (already set for the pipeline).
GEO_ENABLED=
# Per-engine keys (set the ones you have; unset engines are skipped):
PERPLEXITY_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Optional model overrides (vendor model ids drift):
GEO_OPENAI_MODEL=
GEO_PERPLEXITY_MODEL=
GEO_GEMINI_MODEL=
# Cost caps (defaults: 3 engines × 4 probes = 12 answers/run max):
GEO_MAX_ENGINES=
GEO_MAX_PROBES=
# Email the flagged findings (opt-in, like the report): needs GEO_ALERTS_ENABLED=1.
GEO_ALERTS_ENABLED=
GEO_TO=
